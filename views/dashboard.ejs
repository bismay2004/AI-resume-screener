<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — ResumeAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body class="bg-light">

<!-- ── NAVBAR ─────────────────────────────────────────── -->
<nav class="navbar navbar-dark bg-primary py-2">
  <div class="container-fluid px-3 px-md-4">
    <a class="navbar-brand fw-bold" href="/home"><i class="bi bi-robot me-2"></i><span class="d-none d-sm-inline">ResumeAI</span></a>
    <!-- Mobile hamburger - opens offcanvas -->
    <button class="navbar-toggler border-0 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#dashboardNav" aria-controls="dashboardNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <!-- Desktop nav -->
    <div class="ms-auto d-none d-md-flex align-items-center gap-2 gap-md-3 flex-wrap">
      <span class="text-white-75 small d-none d-lg-block">
        <i class="bi bi-person-circle me-1"></i><%= user.name %>
      </span>
      <a href="/resume/upload" class="btn btn-light btn-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i>New Analysis
      </a>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </div>
</nav>

<!-- Mobile Offcanvas Sidebar Navigation -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="dashboardNav" aria-labelledby="dashboardNavLabel">
  <div class="offcanvas-header border-bottom">
    <h5 class="offcanvas-title fw-bold" id="dashboardNavLabel">
      <i class="bi bi-robot me-2"></i>ResumeAI
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body p-0">
    <div class="px-4 py-3 border-bottom text-muted small">
      <i class="bi bi-person-circle me-2"></i><%= user.name %>
    </div>
    <ul class="nav flex-column gap-0">
      <li class="nav-item">
        <a href="/home" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-house me-2"></i>Home
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis/dashboard" class="nav-link px-4 py-3 border-bottom text-primary fw-semibold">
          <i class="bi bi-grid me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/resume/upload" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-plus-lg me-2"></i>New Analysis
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-clock-history me-2"></i>History
        </a>
      </li>
      <li class="nav-item">
        <a href="/logout" class="nav-link px-4 py-3 border-bottom text-danger">
          <i class="bi bi-box-arrow-right me-2"></i>Logout
        </a>
      </li>
    </ul>
  </div>
</div>
  </div>
</nav>

<!-- ── SIDEBAR + CONTENT ──────────────────────────────── -->
<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-12 col-md-3 col-lg-2 sidebar-bg min-vh-md-100 py-3 py-md-4 d-none d-md-block">
      <ul class="nav flex-column gap-1 px-2">
        <li class="nav-item">
          <a href="/home" class="nav-link text-dark small">
            <i class="bi bi-house me-2"></i>Home
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis/dashboard" class="nav-link active fw-semibold small">
            <i class="bi bi-grid me-2"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a href="/resume/upload" class="nav-link text-dark small">
            <i class="bi bi-upload me-2"></i>New Analysis
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis" class="nav-link text-dark small">
            <i class="bi bi-clock-history me-2"></i>History
          </a>
        </li>
        <li class="nav-item mt-4">
          <a href="/logout" class="nav-link text-muted small">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
          </a>
        </li>
      </ul>
    </div>

    <!-- Main content -->
    <div class="col-12 col-md-9 col-lg-10 py-3 py-md-4 px-3 px-md-4">

      <!-- Header -->
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-sm-items-center mb-4 gap-2">
        <div>
          <h4 class="fw-bold mb-0">Hello, <%= user.name.split(' ')[0] %> 👋</h4>
          <p class="text-muted small mb-0">Here's your resume analysis overview</p>
        </div>
        <a href="/resume/upload" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i>Analyze New Resume
        </a>
      </div>

      <!-- Stats Row -->
      <div class="row g-2 g-md-4 mb-4">
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 p-1">
            <div class="card-body p-2 p-md-3">
              <div class="d-flex align-items-center">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-3 me-2 me-md-3">
                   <i class="bi bi-file-earmark-text fs-5"></i>
                </div>
                <div class="small">
                  <div class="text-muted tiny">Total Analyses</div>
                  <div class="fs-5 fw-bold"><%= totalAnalyses %></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 p-1">
            <div class="card-body p-2 p-md-3">
              <div class="d-flex align-items-center">
                <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 me-2 me-md-3">
                   <i class="bi bi-speedometer2 fs-5"></i>
                </div>
                <div class="small">
                  <div class="text-muted tiny">Average ATS Score</div>
                  <div class="fs-5 fw-bold"><%= avgScore %><span class="fs-6 text-muted">/100</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 p-1">
            <div class="card-body p-2 p-md-3">
              <div class="d-flex align-items-center">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-3 me-2 me-md-3">
                   <i class="bi bi-calendar-check fs-5"></i>
                </div>
                <div class="small">
                  <div class="text-muted tiny">Member Since</div>
                  <div class="fw-semibold"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) %></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Analyses -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3 d-flex flex-column flex-sm-row justify-content-between align-items-start align-sm-items-center gap-2">
          <h6 class="fw-bold mb-0 small">Recent Analyses</h6>
          <a href="/analysis" class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="card-body p-0">
          <% if (recentAnalyses.length === 0) { %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-inbox fs-1 d-block mb-3"></i>
              <p class="small">No analyses yet. <a href="/resume/upload">Upload your first resume!</a></p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0 small">
                <thead class="bg-light">
                  <tr>
                    <th class="ps-3 ps-md-4 py-2 fw-semibold">Job Title</th>
                    <th class="fw-semibold py-2 d-none d-sm-table-cell">ATS Score</th>
                    <th class="fw-semibold py-2 d-none d-md-table-cell">Skill Match</th>
                    <th class="fw-semibold py-2 d-none d-lg-table-cell">Date</th>
                    <th class="fw-semibold py-2">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentAnalyses.forEach(analysis => { %>
                    <tr>
                      <td class="ps-3 ps-md-4 fw-semibold py-2"><%= analysis.jobTitle.substring(0, 20) %>...</td>
                      <td class="py-2 d-none d-sm-table-cell">
                        <div class="d-flex align-items-center gap-1">
                          <div class="progress flex-grow-1" style="height:6px;width:60px;">
                            <div class="progress-bar <%= analysis.atsScore >= 80 ? 'bg-success' : analysis.atsScore >= 60 ? 'bg-warning' : 'bg-danger' %>"
                                 style="width:<%= analysis.atsScore %>%"></div>
                          </div>
                          <span class="fw-semibold tiny"><%= analysis.atsScore %>%</span>
                        </div>
                      </td>
                      <td class="py-2 d-none d-md-table-cell"><span class="badge bg-info-subtle text-info fw-semibold tiny"><%= analysis.skillMatch %>%</span></td>
                      <td class="text-muted tiny py-2 d-none d-lg-table-cell"><%= new Date(analysis.createdAt).toLocaleDateString('en-IN') %></td>
                      <td class="py-2">
                        <a href="/analysis/<%= analysis._id %>" class="btn btn-outline-primary btn-sm">View</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Quick Action -->
      <% if (totalAnalyses === 0) { %>
      <div class="alert alert-primary border-0 rounded-4 mt-4 d-flex flex-column flex-sm-row align-items-start align-sm-items-center gap-2">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div class="small">
          <strong>Get started!</strong> Upload your resume PDF and paste a job description to get your first AI-powered analysis.
          <a href="/resume/upload" class="alert-link ms-1">Start now →</a>
        </div>
      </div>
      <% } %>

    </div><!-- /main content -->
  </div><!-- /row -->
</div><!-- /container-fluid -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Handle offcanvas menu clicks - properly navigate and close
  document.addEventListener('DOMContentLoaded', function() {
    const offcanvasElement = document.getElementById('dashboardNav');
    if (!offcanvasElement) return;
    
    const offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
    const navLinks = offcanvasElement.querySelectorAll('.nav-link');
    
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href) {
          offcanvasInstance.hide();
          setTimeout(() => { window.location.href = href; }, 100);
          e.preventDefault();
        }
      });
    });
  });
</script>
</body>
</html>
