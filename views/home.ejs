<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ResumeAI — Smart Resume Screening</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

<!-- ── NAVBAR ─────────────────────────────────────────── -->
<nav class="navbar navbar-dark bg-primary py-2 py-md-3">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold fs-4" href="/">
      <i class="bi bi-robot me-2"></i><span class="d-none d-sm-inline">ResumeAI</span>
    </a>
    <!-- Mobile hamburger - opens offcanvas -->
    <button class="navbar-toggler border-0 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNav" aria-controls="mobileNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <!-- Desktop nav -->
    <div class="ms-auto d-none d-md-flex gap-2 flex-wrap">
      <% if (user) { %>
        <a href="/analysis/dashboard" class="btn btn-light btn-sm">Dashboard</a>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      <% } else { %>
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/signup" class="btn btn-light btn-sm fw-semibold">Get Started</a>
      <% } %>
    </div>
  </div>
</nav>

<!-- Mobile Offcanvas Sidebar Navigation -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileNav" aria-labelledby="mobileNavLabel">
  <div class="offcanvas-header border-bottom">
    <h5 class="offcanvas-title fw-bold" id="mobileNavLabel">
      <i class="bi bi-robot me-2"></i>ResumeAI
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body p-0">
    <ul class="nav flex-column gap-0">
      <li class="nav-item">
        <a href="/home" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-house me-2"></i>Home
        </a>
      </li>
      <% if (user) { %>
        <li class="nav-item">
          <a href="/analysis/dashboard" class="nav-link px-4 py-3 border-bottom text-dark">
            <i class="bi bi-grid me-2"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a href="/resume/upload" class="nav-link px-4 py-3 border-bottom text-dark">
            <i class="bi bi-plus-lg me-2"></i>New Analysis
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis" class="nav-link px-4 py-3 border-bottom text-dark">
            <i class="bi bi-clock-history me-2"></i>History
          </a>
        </li>
        <li class="nav-item mt-auto">
          <a href="/logout" class="nav-link px-4 py-3 border-bottom text-danger">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
          </a>
        </li>
      <% } else { %>
        <li class="nav-item">
          <a href="/login" class="nav-link px-4 py-3 border-bottom text-dark">
            <i class="bi bi-box-arrow-in-right me-2"></i>Login
          </a>
        </li>
        <li class="nav-item">
          <a href="/signup" class="nav-link px-4 py-3 border-bottom text-dark">
            <i class="bi bi-person-plus me-2"></i>Sign Up
          </a>
        </li>
      <% } %>
    </ul>
  </div>
</div>

<!-- ── HERO ───────────────────────────────────────────── -->
<section class="hero-section text-center py-3 py-md-5">
  <div class="container-fluid px-3 px-md-4 py-3 py-md-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-8">
        <span class="badge bg-primary-subtle text-primary fw-semibold px-3 py-2 rounded-pill mb-3 d-inline-block">
          Powered by Google Gemini AI
        </span>
        <h1 class="display-4 fw-bold text-dark mb-3 mb-md-4">
          Know If Your Resume Will <span class="text-primary">Beat the ATS</span>
        </h1>
        <p class="lead text-muted mb-4 mb-md-5">
          Upload your resume, paste any job description, and get an instant AI-powered analysis — 
          ATS score, skill gaps, recruiter feedback, and actionable improvements.
        </p>
        <div class="d-flex gap-2 gap-md-3 justify-content-center flex-column flex-sm-row">
          <% if (user) { %>
            <a href="/resume/upload" class="btn btn-primary btn-lg px-4 py-2 px-md-5 py-md-3 fw-semibold">
              Analyze My Resume <i class="bi bi-arrow-right ms-2 d-none d-sm-inline"></i>
            </a>
          <% } else { %>
            <a href="/signup" class="btn btn-primary btn-lg px-4 py-2 px-md-5 py-md-3 fw-semibold">
              Analyze My Resume <i class="bi bi-arrow-right ms-2 d-none d-sm-inline"></i>
            </a>
            <a href="/login" class="btn btn-outline-secondary btn-lg px-4 py-2 px-md-5 py-md-3">
              Sign In
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── STATS ──────────────────────────────────────────── -->
<section class="bg-primary text-white py-3 py-md-4">
  <div class="container-fluid px-3 px-md-4">
    <div class="row text-center g-3 g-md-4">
      <div class="col-6 col-md-4">
        <div class="fs-2 fw-bold">75%</div>
        <div class="text-white-50 small">Resumes rejected by ATS before human review</div>
      </div>
      <div class="col-6 col-md-4">
        <div class="fs-2 fw-bold">6 sec</div>
        <div class="text-white-50 small">Average recruiter time spent per resume</div>
      </div>
      <div class="col-12 col-md-4">
        <div class="fs-2 fw-bold">2x</div>
        <div class="text-white-50 small">Higher callback rate with optimized resumes</div>
      </div>
    </div>
  </div>
</section>

<!-- ── FEATURES ───────────────────────────────────────── -->
<section class="py-3 py-md-5 bg-light">
  <div class="container-fluid px-3 px-md-4 py-2 py-md-4">
    <h2 class="text-center fw-bold mb-3 mb-md-5">Everything You Need to Land the Interview</h2>
    <div class="row g-3 g-md-4">
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-speedometer2 fs-2"></i>
            </div>
            <h5 class="fw-bold">ATS Score</h5>
            <p class="text-muted text-sm">Get a 0–100 compatibility score showing how well your resume passes automated screening systems.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-success bg-opacity-10 text-success rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-clipboard-check fs-2"></i>
            </div>
            <h5 class="fw-bold">Skill Gap Analysis</h5>
            <p class="text-muted text-sm">See exactly which skills from the job description you have and which ones you're missing.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-warning bg-opacity-10 text-warning rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-lightbulb fs-2"></i>
            </div>
            <h5 class="fw-bold">AI Suggestions</h5>
            <p class="text-muted text-sm">Get specific, actionable improvement tips written by AI trained on thousands of successful resumes.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-info bg-opacity-10 text-info rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-person-check fs-2"></i>
            </div>
            <h5 class="fw-bold">Recruiter Feedback</h5>
            <p class="text-muted text-sm">Receive honest strengths and weaknesses analysis as if a senior recruiter reviewed your resume.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-danger bg-opacity-10 text-danger rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-clock-history fs-2"></i>
            </div>
            <h5 class="fw-bold">Analysis History</h5>
            <p class="text-muted text-sm">Track your improvement over time. Compare scores across different job applications.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 p-2">
          <div class="card-body text-center p-3 p-md-4">
            <div class="feature-icon bg-secondary bg-opacity-10 text-secondary rounded-3 mx-auto mb-3 mb-md-4">
              <i class="bi bi-shield-lock fs-2"></i>
            </div>
            <h5 class="fw-bold">Secure & Private</h5>
            <p class="text-muted text-sm">Your resume data is encrypted and linked only to your account. We never share your data.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ────────────────────────────────────── -->
<section class="py-3 py-md-5">
  <div class="container-fluid px-3 px-md-4 py-2 py-md-4">
    <h2 class="text-center fw-bold mb-3 mb-md-5">How It Works</h2>
    <div class="row align-items-center g-3 g-md-5">
      <div class="col-12 col-md-6">
        <div class="d-flex align-items-start mb-3 mb-md-4">
          <div class="step-num bg-primary text-white rounded-circle fw-bold flex-shrink-0 me-3">1</div>
          <div>
            <h5 class="fw-bold">Create Your Account</h5>
            <p class="text-muted mb-0 small">Sign up in seconds. No credit card required.</p>
          </div>
        </div>
        <div class="d-flex align-items-start mb-3 mb-md-4">
          <div class="step-num bg-primary text-white rounded-circle fw-bold flex-shrink-0 me-3">2</div>
          <div>
            <h5 class="fw-bold">Upload Your Resume PDF</h5>
            <p class="text-muted mb-0 small">We extract the text automatically using advanced PDF processing.</p>
          </div>
        </div>
        <div class="d-flex align-items-start mb-3 mb-md-4">
          <div class="step-num bg-primary text-white rounded-circle fw-bold flex-shrink-0 me-3">3</div>
          <div>
            <h5 class="fw-bold">Paste the Job Description</h5>
            <p class="text-muted mb-0 small">Copy any JD from LinkedIn, Naukri, or company websites.</p>
          </div>
        </div>
        <div class="d-flex align-items-start">
          <div class="step-num bg-success text-white rounded-circle fw-bold flex-shrink-0 me-3">4</div>
          <div>
            <h5 class="fw-bold">Get Your AI Analysis</h5>
            <p class="text-muted mb-0 small">Google Gemini AI analyzes your resume and delivers detailed feedback in seconds.</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 text-center mt-3 mt-md-0">
        <div class="bg-light rounded-4 p-3 p-md-5 border">
          <i class="bi bi-robot text-primary d-block mb-3" style="font-size:4rem;"></i>
          <p class="text-muted mt-2 mb-0 small">Google Gemini AI performs recruiter-grade analysis in seconds</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA ────────────────────────────────────────────── -->
<section class="bg-primary text-white py-3 py-md-5">
  <div class="container-fluid px-3 px-md-4 text-center py-2 py-md-3">
    <h2 class="fw-bold mb-2 mb-md-3">Ready to Optimize Your Resume?</h2>
    <p class="lead text-white-75 mb-3 mb-md-4">Join thousands of job seekers who've improved their interview chances.</p>
    <a href="/signup" class="btn btn-light btn-lg fw-bold px-4 py-2 px-md-5">Start for Free</a>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────── -->
<footer class="bg-dark text-white-50 py-3 py-md-4 text-center text-sm">
  <div class="container-fluid px-3 px-md-4">
    <p class="mb-0 small">© 2024 ResumeAI &nbsp;|&nbsp; Built with Node.js, Express, MongoDB & Google Gemini</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Handle offcanvas menu clicks - properly navigate and close
  document.addEventListener('DOMContentLoaded', function() {
    const offcanvasElement = document.getElementById('mobileNav');
    if (!offcanvasElement) return;
    
    const offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
    const navLinks = offcanvasElement.querySelectorAll('.nav-link');
    
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href) {
          offcanvasInstance.hide();
          // Navigate after a tiny delay to ensure drawer closes
          setTimeout(() => { window.location.href = href; }, 100);
          e.preventDefault();
        }
      });
    });
  });
</script>
</body>
</html>
