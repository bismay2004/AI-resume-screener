<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upload Resume — ResumeAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body class="bg-light">

<!-- ── NAVBAR ─────────────────────────────────────────── -->
<nav class="navbar navbar-dark bg-primary py-2">
  <div class="container-fluid px-3 px-md-4">
    <a class="navbar-brand fw-bold" href="/home"><i class="bi bi-robot me-2"></i><span class="d-none d-sm-inline">ResumeAI</span></a>
    <!-- Mobile hamburger - opens offcanvas -->
    <button class="navbar-toggler border-0 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#uploadNav" aria-controls="uploadNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <!-- Desktop nav -->
    <div class="ms-auto d-none d-md-flex gap-2 flex-wrap">
      <a href="/analysis/dashboard" class="btn btn-outline-light btn-sm">Dashboard</a>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </div>
</nav>

<!-- Mobile Offcanvas Sidebar Navigation -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="uploadNav" aria-labelledby="uploadNavLabel">
  <div class="offcanvas-header border-bottom">
    <h5 class="offcanvas-title fw-bold" id="uploadNavLabel">
      <i class="bi bi-robot me-2"></i>ResumeAI
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body p-0">
    <ul class="nav flex-column gap-0">
      <li class="nav-item">
        <a href="/home" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-house me-2"></i>Home
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis/dashboard" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-grid me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/resume/upload" class="nav-link px-4 py-3 border-bottom text-primary fw-semibold">
          <i class="bi bi-plus-lg me-2"></i>New Analysis
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-clock-history me-2"></i>History
        </a>
      </li>
      <li class="nav-item mt-auto">
        <a href="/logout" class="nav-link px-4 py-3 border-bottom text-danger">
          <i class="bi bi-box-arrow-right me-2"></i>Logout
        </a>
      </li>
    </ul>
  </div>
</div>

<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-12 col-md-3 col-lg-2 sidebar-bg min-vh-md-100 py-3 py-md-4 d-none d-md-block">
      <ul class="nav flex-column gap-1 px-2">
        <li class="nav-item">
          <a href="/home" class="nav-link text-dark small">
            <i class="bi bi-house me-2"></i>Home
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis/dashboard" class="nav-link text-dark small">
            <i class="bi bi-grid me-2"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a href="/resume/upload" class="nav-link active fw-semibold small">
            <i class="bi bi-upload me-2"></i>New Analysis
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis" class="nav-link text-dark small">
            <i class="bi bi-clock-history me-2"></i>History
          </a>
        </li>
        <li class="nav-item mt-4">
          <a href="/logout" class="nav-link text-muted small">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
          </a>
        </li>
      </ul>
    </div>

    <!-- Main content -->
    <div class="col-12 col-md-9 col-lg-10 py-3 py-md-5 px-3 px-md-4">
      <div class="row justify-content-center">
        <div class="col-12 col-md-11 col-lg-8">

      <!-- Page header -->
      <div class="mb-4">
        <h4 class="fw-bold">New Resume Analysis</h4>
        <p class="text-muted small">Upload your resume and paste a job description to get an AI-powered analysis.</p>
      </div>

      <!-- Error alert -->
      <% if (error) { %>
        <div class="alert alert-danger rounded-3 mb-4">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
        </div>
      <% } %>

      <!-- Upload form -->
      <form action="/resume/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

        <!-- Resume PDF Upload -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-3 p-md-4">
            <h6 class="fw-bold mb-3 small">
              <i class="bi bi-file-earmark-pdf text-danger me-2"></i>Resume PDF
            </h6>

            <div class="upload-zone rounded-3 text-center p-3 p-md-5 border-2 border-dashed" id="dropZone">
              <i class="bi bi-cloud-upload fs-1 text-muted mb-3 d-block"></i>
              <p class="text-muted mb-1 small">Drag & drop your resume here, or</p>
              <label for="resume" class="btn btn-outline-primary btn-sm mt-2 mb-0">
                Browse File
              </label>
              <input
                type="file"
                id="resume"
                name="resume"
                accept=".pdf"
                class="d-none"
                required
              />
              <p class="text-muted small mt-3 mb-0">PDF files only · Max 5MB</p>
              <div id="fileNameDisplay" class="mt-2 text-primary fw-semibold d-none small"></div>
            </div>
          </div>
        </div>

        <!-- Job Details -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-3 p-md-4">
            <h6 class="fw-bold mb-3 small">
              <i class="bi bi-briefcase text-primary me-2"></i>Job Details
            </h6>

            <div class="mb-3">
              <label for="jobTitle" class="form-label fw-semibold small">Job Title / Company</label>
              <input
                type="text"
                id="jobTitle"
                name="jobTitle"
                class="form-control"
                placeholder="e.g. SDE-1 at Amazon"
                required
              />
              <div class="form-text small">This label helps identify the analysis in your history.</div>
            </div>

            <div class="mb-0">
              <label for="jobDescription" class="form-label fw-semibold small">Job Description</label>
              <textarea
                id="jobDescription"
                name="jobDescription"
                class="form-control"
                rows="8"
                placeholder="Paste the full job description here..."
                required
              ></textarea>
              <div class="form-text small">Paste the complete JD for the most accurate analysis.</div>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="d-grid">
          <button type="submit" class="btn btn-primary btn-lg fw-semibold" id="submitBtn">
            <i class="bi bi-cpu me-2"></i>Analyze with AI
          </button>
        </div>

      </form>

      <!-- Analysis Info -->
      <div class="alert alert-info border-0 rounded-3 mt-4 small">
        <i class="bi bi-info-circle me-2"></i>
        Analysis typically takes 5–15 seconds depending on resume length.
        Google Gemini AI will compare your resume against the job description.
      </div>

      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/upload.js"></script>
<script>
  // Handle offcanvas menu clicks - properly navigate and close
  document.addEventListener('DOMContentLoaded', function() {
    const offcanvasElement = document.getElementById('uploadNav');
    if (!offcanvasElement) return;
    
    const offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
    const navLinks = offcanvasElement.querySelectorAll('.nav-link');
    
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href) {
          offcanvasInstance.hide();
          setTimeout(() => { window.location.href = href; }, 100);
          e.preventDefault();
        }
      });
    });
  });
</script>
</body>
</html>
