<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analysis History — ResumeAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body class="bg-light">

<!-- ── NAVBAR ─────────────────────────────────────────── -->
<nav class="navbar navbar-expand-md navbar-dark bg-primary py-2">
  <div class="container-fluid px-3 px-md-4">
    <a class="navbar-brand fw-bold" href="/home"><i class="bi bi-robot me-2"></i><span class="d-none d-sm-inline">ResumeAI</span></a>
    <!-- Mobile hamburger - opens offcanvas -->
    <button class="navbar-toggler border-0 d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#historyNav" aria-controls="historyNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <!-- Desktop nav -->
    <div class="ms-auto d-none d-md-flex gap-2 flex-wrap">
      <a href="/analysis/dashboard" class="btn btn-outline-light btn-sm">Dashboard</a>
      <a href="/resume/upload" class="btn btn-light btn-sm fw-semibold">New Analysis</a>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </div>
</nav>

<!-- Mobile Offcanvas Sidebar Navigation -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="historyNav" aria-labelledby="historyNavLabel">
  <div class="offcanvas-header border-bottom">
    <h5 class="offcanvas-title fw-bold" id="historyNavLabel">
      <i class="bi bi-robot me-2"></i>ResumeAI
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body p-0">
    <ul class="nav flex-column gap-0">
      <li class="nav-item">
        <a href="/home" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-house me-2"></i>Home
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis/dashboard" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-grid me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/resume/upload" class="nav-link px-4 py-3 border-bottom text-dark">
          <i class="bi bi-plus-lg me-2"></i>New Analysis
        </a>
      </li>
      <li class="nav-item">
        <a href="/analysis" class="nav-link px-4 py-3 border-bottom text-primary fw-semibold">
          <i class="bi bi-clock-history me-2"></i>History
        </a>
      </li>
      <li class="nav-item">
        <a href="/logout" class="nav-link px-4 py-3 border-bottom text-danger">
          <i class="bi bi-box-arrow-right me-2"></i>Logout
        </a>
      </li>
    </ul>
  </div>
  </div>
</nav>

<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-12 col-md-3 col-lg-2 sidebar-bg min-vh-md-100 py-3 py-md-4 d-none d-md-block">
      <ul class="nav flex-column gap-1 px-2">
        <li class="nav-item">
          <a href="/home" class="nav-link text-dark small">
            <i class="bi bi-house me-2"></i>Home
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis/dashboard" class="nav-link text-dark small">
            <i class="bi bi-grid me-2"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a href="/resume/upload" class="nav-link text-dark small">
            <i class="bi bi-upload me-2"></i>New Analysis
          </a>
        </li>
        <li class="nav-item">
          <a href="/analysis" class="nav-link active fw-semibold small">
            <i class="bi bi-clock-history me-2"></i>History
          </a>
        </li>
        <li class="nav-item mt-4">
          <a href="/logout" class="nav-link text-muted small">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
          </a>
        </li>
      </ul>
    </div>

    <!-- Main content -->
    <div class="col-12 col-md-9 col-lg-10 py-3 py-md-4 px-3 px-md-4">
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-sm-items-center mb-4 gap-2">
    <div>
      <h4 class="fw-bold mb-0">Analysis History</h4>
      <p class="text-muted small mb-0">All your past resume analyses</p>
    </div>
    <a href="/resume/upload" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>New Analysis
    </a>
  </div>

  <% if (analyses.length === 0) { %>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
        <h6 class="fw-semibold">No analyses yet</h6>
        <p class="text-muted small">Upload your first resume to get started.</p>
        <a href="/resume/upload" class="btn btn-primary">Upload Resume</a>
      </div>
    </div>
  <% } else { %>

    <!-- Summary bar -->
    <div class="alert alert-info border-0 rounded-3 mb-4 tiny">
      <i class="bi bi-bar-chart me-2"></i>
      You have <strong><%= analyses.length %></strong> total analysis
      <%= analyses.length === 1 ? '' : 'sessions' %>.
      Average ATS score:
      <strong>
        <%= Math.round(analyses.reduce((sum, a) => sum + a.atsScore, 0) / analyses.length) %>
      </strong>.
    </div>

    <div class="row g-2 g-md-4">
      <% analyses.forEach(analysis => { %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card border-0 shadow-sm rounded-4 h-100 history-card">
            <div class="card-body p-3 p-md-4">

              <!-- Header -->
              <div class="d-flex justify-content-between align-items-start mb-3">
                <h6 class="fw-bold mb-0 me-2"><%= analysis.jobTitle %></h6>
                <span class="badge rounded-pill
                  <%= analysis.atsScore >= 80 ? 'bg-success' : analysis.atsScore >= 60 ? 'bg-warning text-dark' : 'bg-danger' %>
                  flex-shrink-0">
                  <%= analysis.atsScore %>%
                </span>
              </div>

              <!-- File name -->
              <% if (analysis.resumeId) { %>
                <p class="text-muted small mb-3">
                  <i class="bi bi-file-earmark-pdf text-danger me-1"></i>
                  <%= analysis.resumeId.originalFileName %>
                </p>
              <% } %>

              <!-- Score bars -->
              <div class="mb-2">
                <div class="d-flex justify-content-between small mb-1">
                  <span class="text-muted">ATS Score</span>
                  <span class="fw-semibold"><%= analysis.atsScore %>%</span>
                </div>
                <div class="progress" style="height:6px;">
                  <div class="progress-bar <%= analysis.atsScore >= 80 ? 'bg-success' : analysis.atsScore >= 60 ? 'bg-warning' : 'bg-danger' %>"
                       style="width:<%= analysis.atsScore %>%"></div>
                </div>
              </div>

              <div class="mb-3">
                <div class="d-flex justify-content-between small mb-1">
                  <span class="text-muted">Skill Match</span>
                  <span class="fw-semibold"><%= analysis.skillMatch %>%</span>
                </div>
                <div class="progress" style="height:6px;">
                  <div class="progress-bar bg-info" style="width:<%= analysis.skillMatch %>%"></div>
                </div>
              </div>

              <!-- Skills preview -->
              <div class="mb-3">
                <div class="d-flex flex-wrap gap-1">
                  <% analysis.matchingSkills.slice(0, 3).forEach(skill => { %>
                    <span class="badge bg-success-subtle text-success small"><%= skill %></span>
                  <% }) %>
                  <% if (analysis.matchingSkills.length > 3) { %>
                    <span class="badge bg-secondary-subtle text-secondary small">+<%= analysis.matchingSkills.length - 3 %> more</span>
                  <% } %>
                </div>
              </div>

              <!-- Footer -->
              <div class="d-flex justify-content-between align-items-center mt-auto">
                <span class="text-muted small">
                  <i class="bi bi-calendar me-1"></i>
                  <%= new Date(analysis.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                </span>
                <div class="d-flex gap-2">
                  <button
                    class="btn btn-outline-danger btn-sm"
                    onclick="deleteAnalysis('<%= analysis._id %>', this)"
                    title="Delete"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
                  <a href="/analysis/<%= analysis._id %>" class="btn btn-primary btn-sm">
                    View <i class="bi bi-arrow-right ms-1"></i>
                  </a>
                </div>
              </div>

            </div>
          </div>
        </div>
      <% }) %>
    </div>

  <% } %>
    </div>
  </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content border-0 rounded-4">
      <div class="modal-body text-center p-4">
        <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-3 d-block"></i>
        <h6 class="fw-bold">Delete this analysis?</h6>
        <p class="text-muted small mb-4">This action cannot be undone.</p>
        <div class="d-flex gap-2 justify-content-center">
          <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-danger btn-sm" id="confirmDeleteBtn">Delete</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/history.js"></script>
<script>
  // Handle offcanvas menu clicks - properly navigate and close
  document.addEventListener('DOMContentLoaded', function() {
    const offcanvasElement = document.getElementById('historyNav');
    if (!offcanvasElement) return;
    
    const offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);
    const navLinks = offcanvasElement.querySelectorAll('.nav-link');
    
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href) {
          offcanvasInstance.hide();
          setTimeout(() => { window.location.href = href; }, 100);
          e.preventDefault();
        }
      });
    });
  });
</script>
</body>
</html>
